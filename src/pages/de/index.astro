---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import CookieBanner from '../../components/CookieBanner.astro';

const discordInvite = "https://discord.gg/Js3c3ynRRd";
---

<html lang="de">
<head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
</head>
<body>
    <Header />

    <main>
        <section class="hero">
            <h1>BuildMC Launcher</h1>
            <p>Der individuelle Minecraft Launcher für Modpacks, Server und nahtloses Multiplayer-Erlebnis.</p>
            <a href="/de/downloads" class="btn btn-primary">Launcher herunterladen</a>
            <a href="/de/downloads" class="btn btn-secondary">Downloads durchsuchen</a>
        </section>

        <section>
            <h2>Features</h2>
            <div class="features">
                <div class="feature-card">
                    <h3>Modpack Support</h3>
                    <p>Importiere und spiele Modrinth Modpacks direkt aus dem Launcher.</p>
                </div>
                <div class="feature-card">
                    <h3>Server-Integration</h3>
                    <p>Speichere Lieblingsserver, pinge sie und trete mit einem Klick bei.</p>
                </div>
                <div class="feature-card">
                    <h3>Account-Verwaltung</h3>
                    <p>Microsoft-Login mit sicherer Token-Speicherung.</p>
                </div>
                <div class="feature-card">
                    <h3>SwiftServers</h3>
                    <p>Verwalte dein SwiftServers-Hosting direkt aus dem Launcher.</p>
                </div>
                <div class="feature-card">
                    <h3>Fabric & Mods</h3>
                    <p>Installiere Fabric und verwalte Mods pro Instanz automatisch.</p>
                </div>
                <div class="feature-card">
                    <h3>Discord Rich Presence</h3>
                    <p>Zeige deinen Freunden, was du spielst, mit Discord-Status.</p>
                </div>
            </div>
        </section>

        <section>
            <h2>Loslegen</h2>
            <p>
                Lade den aktuellen BuildMC Launcher Installer herunter, installiere ihn und starte auf deinen Lieblingsservern.
                Kostenlos, offen und für die Community gemacht.
            </p>
            <a href="/de/downloads" class="btn btn-primary">Für Windows herunterladen</a>
            <a href={discordInvite} target="_blank" rel="noopener noreferrer" class="btn btn-secondary">Discord beitreten</a>
        </section>
    </main>

    <Footer />
    <CookieBanner />
</body>
</html>

---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import CookieBanner from '../components/CookieBanner.astro';

const discordInvite = "https://discord.gg/Js3c3ynRRd";
---

<html lang="en">
<head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
</head>
<body>
    <Header />

    <main>
        <section class="hero">
            <h1>BuildMC Launcher</h1>
            <p>The custom Minecraft launcher built for modpacks, servers, and seamless multiplayer.</p>
            <a href="/downloads" class="btn btn-primary">Download Launcher</a>
            <a href="/downloads" class="btn btn-secondary">Browse Downloads</a>
        </section>

        <section>
            <h2>Features</h2>
            <div class="features">
                <div class="feature-card">
                    <h3>Modpack Support</h3>
                    <p>Import and play Modrinth modpacks directly from the launcher.</p>
                </div>
                <div class="feature-card">
                    <h3>Server Integration</h3>
                    <p>Save favorite servers, ping them, and join with one click.</p>
                </div>
                <div class="feature-card">
                    <h3>Account Management</h3>
                    <p>Microsoft account login with secure token storage.</p>
                </div>
                <div class="feature-card">
                    <h3>SwiftServers</h3>
                    <p>Manage your SwiftServers hosting right from the launcher.</p>
                </div>
                <div class="feature-card">
                    <h3>Fabric & Mods</h3>
                    <p>Install Fabric and manage mods per instance automatically.</p>
                </div>
                <div class="feature-card">
                    <h3>Discord Rich Presence</h3>
                    <p>Show your friends what you're playing with Discord activity status.</p>
                </div>
            </div>
        </section>

        <section>
            <h2>Get Started</h2>
            <p>
                Download the latest BuildMC Launcher installer, install it, and start playing on your favorite servers.
                Free, open, and made for the community.
            </p>
            <a href="/downloads" class="btn btn-primary">Download for Windows</a>
            <a href={discordInvite} target="_blank" rel="noopener noreferrer" class="btn btn-secondary">Join Discord</a>
        </section>
    </main>

    <Footer />
    <CookieBanner />
</body>
</html>
